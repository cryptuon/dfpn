---
interface Props {
  title: string
  description: string
  image?: string
  type?: 'website' | 'article'
  noindex?: boolean
  canonicalUrl?: string
  publishedAt?: string
  updatedAt?: string
  author?: string
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  noindex = false,
  canonicalUrl,
  publishedAt,
  updatedAt,
  author,
} = Astro.props

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://dfpn.cryptuon.com'
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString()
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`
const fullTitle = title.includes('DFPN') ? title : `${title} | DFPN - Deepfake Proof Network`
---

<!-- Primary Meta Tags -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />
{noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow" />}
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title="DFPN Blog" href="/rss.xml" />

<!-- Preconnect -->
<link rel="preconnect" href="https://api.devnet.solana.com" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="DFPN - Deepfake Proof Network" />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Article-specific meta -->
{publishedAt && <meta property="article:published_time" content={publishedAt} />}
{updatedAt && <meta property="article:modified_time" content={updatedAt} />}
{author && <meta name="author" content={author} />}

<!-- JSON-LD slot -->
<slot />
