---
interface Props {
  value: string;
  label: string;
  color?: string;
}

const { value, label, color } = Astro.props;
---

<div class="text-center">
  <p class:list={["text-4xl font-bold", color ?? "text-dfpn-primary-light"]}>{value}</p>
  <p class="text-sm text-gray-400 mt-1">{label}</p>
</div>
