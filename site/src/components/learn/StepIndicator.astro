---
interface Props {
  steps: { number: number; title: string; description: string }[];
  direction?: "vertical" | "horizontal";
}

const { steps, direction = "vertical" } = Astro.props;
---

{direction !== "horizontal" ? (
  <div class="relative space-y-0">
    {steps.map((step, i) => (
      <div class="relative flex gap-4 pb-8 last:pb-0">
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 rounded-full bg-dfpn-primary/20 border-2 border-dfpn-primary flex items-center justify-center text-dfpn-primary-light font-bold text-sm shrink-0">
            {step.number}
          </div>
          {i < steps.length - 1 && (
            <div class="w-0.5 flex-1 bg-dfpn-primary/20 mt-2"></div>
          )}
        </div>
        <div class="pt-1.5">
          <h4 class="text-sm font-semibold text-white">{step.title}</h4>
          <p class="text-sm text-gray-400 mt-1">{step.description}</p>
        </div>
      </div>
    ))}
  </div>
) : (
  <div class="flex items-start gap-0 overflow-x-auto">
    {steps.map((step, i) => (
      <div class="flex items-start min-w-0 flex-1">
        <div class="flex flex-col items-center text-center px-2">
          <div class="w-10 h-10 rounded-full bg-dfpn-primary/20 border-2 border-dfpn-primary flex items-center justify-center text-dfpn-primary-light font-bold text-sm shrink-0">
            {step.number}
          </div>
          <h4 class="text-xs font-semibold text-white mt-2">{step.title}</h4>
          <p class="text-xs text-gray-400 mt-1">{step.description}</p>
        </div>
        {i < steps.length - 1 && (
          <div class="h-0.5 bg-dfpn-primary/20 self-center mt-0 min-w-4 flex-shrink-0" style="margin-top: 20px;"></div>
        )}
      </div>
    ))}
  </div>
)}
