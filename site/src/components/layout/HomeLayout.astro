---
import BaseLayout from './BaseLayout.astro'
import TopNav from './TopNav.astro'

interface Props {
  title: string
  description: string
  image?: string
  type?: 'website' | 'article'
  noindex?: boolean
  canonicalUrl?: string
}

const props = Astro.props
---

<BaseLayout {...props}>
  <slot name="head" slot="head" />
  <TopNav>
    <slot name="header-actions" />
  </TopNav>
  <main>
    <slot />
  </main>
  <!-- Footer -->
  <footer class="border-t border-dfpn-border bg-dfpn-surface mt-20">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <!-- Brand -->
        <div class="md:col-span-1">
          <a href="/" class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg bg-dfpn-primary flex items-center justify-center text-white font-bold text-sm">DF</div>
            <span class="font-bold text-lg text-white">DFPN</span>
          </a>
          <p class="text-sm text-gray-500">Decentralized deepfake detection on Solana.</p>
        </div>
        <!-- Learn -->
        <div>
          <h4 class="text-sm font-semibold text-white mb-3">Learn</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/learn" class="text-gray-400 hover:text-white transition-colors">What is DFPN</a></li>
            <li><a href="/learn/how-it-works" class="text-gray-400 hover:text-white transition-colors">How It Works</a></li>
            <li><a href="/learn/tokenomics" class="text-gray-400 hover:text-white transition-colors">Tokenomics</a></li>
            <li><a href="/learn/detection-models" class="text-gray-400 hover:text-white transition-colors">Detection Models</a></li>
            <li><a href="/learn/faq" class="text-gray-400 hover:text-white transition-colors">FAQ</a></li>
          </ul>
        </div>
        <!-- Network -->
        <div>
          <h4 class="text-sm font-semibold text-white mb-3">Network</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/workers" class="text-gray-400 hover:text-white transition-colors">Workers</a></li>
            <li><a href="/models" class="text-gray-400 hover:text-white transition-colors">Models</a></li>
            <li><a href="/requests" class="text-gray-400 hover:text-white transition-colors">Requests</a></li>
            <li><a href="/blog" class="text-gray-400 hover:text-white transition-colors">Blog</a></li>
          </ul>
        </div>
        <!-- Resources -->
        <div>
          <h4 class="text-sm font-semibold text-white mb-3">Resources</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="https://docs.cryptuon.com/dfpn" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">Documentation ↗</a></li>
            <li><a href="https://github.com/cryptuon/dfpn" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">GitHub ↗</a></li>
            <li><a href="https://arxiv.org/abs/2311.18545" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">Research Paper ↗</a></li>
            <li><a href="/rss.xml" class="text-gray-400 hover:text-white transition-colors">RSS Feed</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-dfpn-border mt-8 pt-8 text-center text-xs text-gray-600">
        &copy; 2026 DFPN - Deepfake Proof Network. Built on Solana.
      </div>
    </div>
  </footer>
</BaseLayout>
