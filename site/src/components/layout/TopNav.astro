---
const currentPath = Astro.url.pathname

const navLinks = [
  { href: '/learn', label: 'Learn' },
  { href: '/workers', label: 'Explorer' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://docs.cryptuon.com/dfpn', label: 'Docs', external: true },
  { href: 'https://arxiv.org/abs/2311.18545', label: 'Paper', external: true },
  { href: 'https://github.com/cryptuon/dfpn', label: 'GitHub', external: true },
]

function isActive(href: string): boolean {
  if (href.startsWith('http')) return false
  if (href === '/') return currentPath === '/'
  return currentPath.startsWith(href)
}
---

<nav class="sticky top-0 z-40 border-b border-dfpn-border bg-dfpn-surface/90 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0">
        <div class="w-8 h-8 rounded-lg bg-dfpn-primary flex items-center justify-center text-white font-bold text-sm">
          DF
        </div>
        <span class="font-bold text-lg text-white hidden sm:block">DFPN</span>
      </a>

      <!-- Center nav links -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-1.5',
              isActive(link.href)
                ? 'bg-dfpn-primary/20 text-dfpn-primary-light'
                : 'text-gray-400 hover:text-white hover:bg-dfpn-surface-light',
            ]}
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}
            {link.external && (
              <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            )}
          </a>
        ))}
      </div>

      <!-- Right side: header actions slot + mobile menu -->
      <div class="flex items-center gap-3">
        <slot />
        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-gray-400 hover:text-white rounded-lg hover:bg-dfpn-surface-light"
          aria-label="Open menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-dfpn-border bg-dfpn-surface">
    <div class="px-4 py-3 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-3 py-2 rounded-lg text-sm font-medium transition-colors',
            isActive(link.href)
              ? 'bg-dfpn-primary/20 text-dfpn-primary-light'
              : 'text-gray-400 hover:text-white hover:bg-dfpn-surface-light',
          ]}
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
          {link.external && ' ↗'}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'))
</script>
