---
import DashboardLayout from '../../components/layout/DashboardLayout.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import AppHeaderIsland from '../../components/vue/AppHeaderIsland.vue'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://dfpn.cryptuon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://dfpn.cryptuon.com/blog' },
  ],
}

const collectionLd = {
  '@type': 'CollectionPage',
  name: 'DFPN Blog',
  description: 'Technical articles on deepfake detection, AI verification, and decentralized media authenticity.',
  url: 'https://dfpn.cryptuon.com/blog',
}
---

<DashboardLayout
  title="Blog | DFPN - Deepfake Detection Articles"
  description="Technical articles on deepfake detection, AI-generated media verification, decentralized consensus, and building with the DFPN protocol."
>
  <Fragment slot="head"><JsonLd data={[breadcrumbLd, collectionLd]} /></Fragment>
  <AppHeaderIsland slot="header-actions" client:only="vue" />

  <div class="space-y-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Blog</h1>
      <p class="text-gray-400 mt-2">Technical articles on deepfake detection, AI verification, and media authenticity.</p>
    </div>

    {posts.length === 0 ? (
      <div class="bg-dfpn-surface border border-dfpn-border rounded-xl p-12 text-center">
        <p class="text-gray-400">No articles published yet. Check back soon.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6 hover:border-dfpn-primary/50 transition-colors group block">
            <div class="flex flex-wrap gap-2 mb-3">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-dfpn-primary/20 text-dfpn-primary-light font-medium">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="text-lg font-semibold text-white mb-2 group-hover:text-dfpn-primary-light transition-colors">
              {post.data.title}
            </h2>
            <p class="text-sm text-gray-400 mb-4 line-clamp-2">{post.data.description}</p>
            <div class="flex items-center gap-3 text-xs text-gray-500">
              <span>{post.data.author}</span>
              <span>&middot;</span>
              <time datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</DashboardLayout>
