---
import DashboardLayout from '../../components/layout/DashboardLayout.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import InfoCard from '../../components/learn/InfoCard.astro'
import StatHighlight from '../../components/learn/StatHighlight.astro'

const webPageLd = {
  '@type': 'WebPage',
  name: 'What is DFPN?',
  description: 'Learn how DFPN coordinates decentralized deepfake detection using economic incentives, multi-model consensus, and on-chain transparency on Solana.',
  url: 'https://dfpn.cryptuon.com/learn',
}

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://dfpn.cryptuon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: 'https://dfpn.cryptuon.com/learn' },
  ],
}

const crisisCards = [
  { title: 'Face Swaps', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z', description: 'Replacing one person\'s face with another in images and video, enabling impersonation and fraud at scale.' },
  { title: 'AI-Generated Images', icon: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z', description: 'Entirely synthetic photos created by diffusion models that are indistinguishable from real photographs.' },
  { title: 'Video Manipulation', icon: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z', description: 'Altered video footage with changed facial expressions, lip movements, or entire body actions.' },
  { title: 'Voice Cloning', icon: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z', description: 'Synthetic audio that replicates a person\'s voice with just seconds of sample material.' },
]

const solutionCards = [
  { title: 'Decentralized Detection', icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', description: 'Multiple independent workers analyze each request - no single point of failure.' },
  { title: 'Economic Incentives', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', description: 'Staking and rewards ensure honest behavior - bad actors get slashed.' },
  { title: 'Multi-Model Consensus', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', description: 'Results from different algorithms are aggregated into reliable verdicts.' },
]

const roleCards = [
  { title: 'Workers', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2', description: 'Run detection hardware and earn DFPN tokens.', link: '/learn/participate/workers' },
  { title: 'Clients', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', description: 'Submit media for deepfake analysis.', link: '/learn/participate/clients' },
  { title: 'Model Developers', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', description: 'Register detection models and earn from usage.', link: '/learn/participate/model-developers' },
]
---

<DashboardLayout
  title="What is DFPN? | Deepfake Proof Network"
  description="Learn how DFPN coordinates decentralized deepfake detection using economic incentives, multi-model consensus, and on-chain transparency on Solana."
>
  <Fragment slot="head">
    <JsonLd data={[webPageLd, breadcrumbLd]} />
  </Fragment>

  <div class="space-y-12">
    <!-- Hero -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-8 text-center space-y-6">
      <h1 class="text-4xl font-bold text-white">The Decentralized Deepfake Detection Network</h1>
      <p class="text-lg text-gray-400 max-w-3xl mx-auto">
        DFPN coordinates independent workers who run AI detection models to analyze media for deepfakes.
        Results are aggregated into consensus verdicts and recorded on the Solana blockchain.
      </p>
      <div class="flex justify-center gap-12 pt-4">
        <StatHighlight value="1B" label="Total Supply" />
        <StatHighlight value="4" label="Detection Models" color="text-emerald-400" />
        <StatHighlight value="Solana" label="Blockchain" color="text-blue-400" />
      </div>
    </section>

    <!-- The Deepfake Crisis -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-2">The Deepfake Crisis</h2>
      <p class="text-gray-400 mb-6">Synthetic media is becoming indistinguishable from reality. These are the primary threat vectors:</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {crisisCards.map((card) => (
          <InfoCard icon={card.icon} title={card.title} description={card.description} />
        ))}
      </div>
    </section>

    <!-- How DFPN Solves It -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-2">How DFPN Solves It</h2>
      <p class="text-gray-400 mb-6">A decentralized protocol that makes deepfake detection reliable, transparent, and economically sustainable.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {solutionCards.map((card) => (
          <InfoCard icon={card.icon} title={card.title} description={card.description} />
        ))}
      </div>
    </section>

    <!-- Three Roles -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-2">Three Roles</h2>
      <p class="text-gray-400 mb-6">DFPN is powered by three types of participants, each with different responsibilities and rewards.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {roleCards.map((card) => (
          <InfoCard icon={card.icon} title={card.title} description={card.description}>
            <a href={card.link} class="inline-block mt-3 text-sm text-dfpn-primary-light hover:underline">
              Learn more &rarr;
            </a>
          </InfoCard>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Ready to explore?</h3>
      <div class="flex flex-wrap gap-4">
        <a href="/" class="px-5 py-2.5 bg-dfpn-primary text-white text-sm font-medium rounded-lg hover:bg-dfpn-primary/80 transition-colors">
          Back to Dashboard
        </a>
        <a href="/learn/faq" class="px-5 py-2.5 bg-dfpn-surface border border-dfpn-border text-gray-400 text-sm font-medium rounded-lg hover:border-dfpn-primary/30 transition-colors">
          Read the FAQ
        </a>
      </div>
    </section>
  </div>
</DashboardLayout>
