---
import DashboardLayout from '../../components/layout/DashboardLayout.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import InfoCard from '../../components/learn/InfoCard.astro'
import StepIndicator from '../../components/learn/StepIndicator.astro'

const howToLd = {
  '@type': 'HowTo',
  name: 'How DFPN Processes a Deepfake Detection Request',
  description: 'Step-by-step guide to how media analysis requests flow through DFPN\'s decentralized detection network.',
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Submit', text: 'Client uploads media and posts analysis request with fee and modalities.' },
    { '@type': 'HowToStep', position: 2, name: 'Route', text: 'Workers poll the indexer for requests matching their supported modalities.' },
    { '@type': 'HowToStep', position: 3, name: 'Download', text: 'Matched workers fetch media from the storage URI (IPFS, Arweave, S3).' },
    { '@type': 'HowToStep', position: 4, name: 'Analyze', text: 'Workers run detection models locally on their own hardware.' },
    { '@type': 'HowToStep', position: 5, name: 'Commit', text: 'Workers submit a hash of their result to Solana (prevents copying).' },
    { '@type': 'HowToStep', position: 6, name: 'Reveal', text: 'After commit window closes, workers reveal their actual results.' },
    { '@type': 'HowToStep', position: 7, name: 'Aggregate', text: 'Results are combined into a consensus verdict using reputation weights.' },
    { '@type': 'HowToStep', position: 8, name: 'Finalize', text: 'Request is marked complete with immutable results on-chain.' },
    { '@type': 'HowToStep', position: 9, name: 'Reward', text: 'Workers and model developers earn based on accuracy and availability.' },
  ],
}

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://dfpn.cryptuon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: 'https://dfpn.cryptuon.com/learn' },
    { '@type': 'ListItem', position: 3, name: 'How It Works', item: 'https://dfpn.cryptuon.com/learn/how-it-works' },
  ],
}

const lifecycleSteps = [
  { number: 1, title: 'Submit', description: 'Client uploads media and posts analysis request with fee and modalities.' },
  { number: 2, title: 'Route', description: 'Workers poll the indexer for requests matching their supported modalities.' },
  { number: 3, title: 'Download', description: 'Matched workers fetch media from the storage URI (IPFS, Arweave, S3).' },
  { number: 4, title: 'Analyze', description: 'Workers run detection models locally on their own hardware.' },
  { number: 5, title: 'Commit', description: 'Workers submit a hash of their result to Solana (prevents copying).' },
  { number: 6, title: 'Reveal', description: 'After commit window closes, workers reveal their actual results.' },
  { number: 7, title: 'Aggregate', description: 'Results are combined into a consensus verdict using reputation weights.' },
  { number: 8, title: 'Finalize', description: 'Request is marked complete with immutable results on-chain.' },
  { number: 9, title: 'Reward', description: 'Workers and model developers earn based on accuracy and availability.' },
]

const commitRevealSteps = [
  { number: 1, title: 'Commit', description: 'Lock answer hash on-chain.' },
  { number: 2, title: 'Wait', description: 'All answers remain hidden.' },
  { number: 3, title: 'Reveal', description: 'Verify answers match hashes.' },
]

const scoringCards = [
  { title: 'Accuracy 50%', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', description: 'Agreement with consensus and ground truth. The most heavily weighted factor in determining worker reputation.' },
  { title: 'Availability 25%', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z', description: 'Percentage of assigned tasks completed. Workers must remain online and responsive to maintain high scores.' },
  { title: 'Latency 15%', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z', description: 'Speed relative to deadline. Faster responses earn better scores, but accuracy always takes priority.' },
  { title: 'Consistency 10%', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', description: 'Variance in result quality over time. Steady, reliable performance is rewarded over erratic bursts.' },
]

const securityGuarantees = [
  'No on-chain inference - DFPN never sees your models. All detection runs locally on worker hardware.',
  'Operator independence - Choose your own hardware, models, and configuration.',
  'Commit-reveal prevents result copying - Cryptographic hashes ensure independent analysis.',
  'Staking + slashing enforces honest behavior - Economic penalties deter bad actors.',
  'Multi-worker consensus prevents manipulation - No single worker can control the outcome.',
]
---

<DashboardLayout
  title="How DFPN Works | Deepfake Proof Network"
  description="Step-by-step guide to how media analysis requests flow through DFPN's decentralized detection network, including commit-reveal protocol and scoring."
>
  <Fragment slot="head">
    <JsonLd data={[howToLd, breadcrumbLd]} />
  </Fragment>

  <div class="space-y-12">
    <!-- Hero -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-8">
      <h1 class="text-4xl font-bold text-white mb-4">How DFPN Works</h1>
      <p class="text-lg text-gray-400 max-w-3xl">
        From media submission to on-chain verdict, here is how a detection request flows through the DFPN network.
      </p>
    </section>

    <!-- Request Lifecycle -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Request Lifecycle</h2>
      <div class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
        <StepIndicator steps={lifecycleSteps} direction="vertical" />
      </div>
    </section>

    <!-- Commit-Reveal Protocol -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-2">Commit-Reveal Protocol</h2>
      <p class="text-gray-400 mb-6">
        The commit-reveal protocol ensures workers analyze media independently. By committing a hash before revealing results, no worker can copy another's answer.
      </p>
      <div class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
        <StepIndicator steps={commitRevealSteps} direction="horizontal" />
      </div>
    </section>

    <!-- Scoring Factors -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-2">Scoring Factors</h2>
      <p class="text-gray-400 mb-6">Worker reputation is determined by four weighted factors:</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {scoringCards.map((card) => (
          <InfoCard icon={card.icon} title={card.title} description={card.description} />
        ))}
      </div>
    </section>

    <!-- Security Guarantees -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Security Guarantees</h2>
      <div class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6 space-y-4">
        {securityGuarantees.map((guarantee) => (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-dfpn-primary-light mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <p class="text-sm text-gray-400">{guarantee}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Navigation -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Continue learning</h3>
      <div class="flex flex-wrap gap-4">
        <a href="/learn" class="px-5 py-2.5 bg-dfpn-primary text-white text-sm font-medium rounded-lg hover:bg-dfpn-primary/80 transition-colors">
          What is DFPN?
        </a>
        <a href="/learn/tokenomics" class="px-5 py-2.5 bg-dfpn-surface border border-dfpn-border text-gray-400 text-sm font-medium rounded-lg hover:border-dfpn-primary/30 transition-colors">
          Token Economics
        </a>
        <a href="/learn/detection-models" class="px-5 py-2.5 bg-dfpn-surface border border-dfpn-border text-gray-400 text-sm font-medium rounded-lg hover:border-dfpn-primary/30 transition-colors">
          Detection Models
        </a>
      </div>
    </section>
  </div>
</DashboardLayout>
