---
import DashboardLayout from '../../components/layout/DashboardLayout.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import FaqAccordion from '@dashboard/components/learn/FaqAccordion.vue'

const generalFaqs = [
  { question: 'What is DFPN?', answer: 'DFPN is a decentralized coordination layer for deepfake detection built on Solana. It connects clients who need media verified with independent workers who run detection algorithms, using economic incentives to ensure honest behavior.' },
  { question: 'How is DFPN different from centralized detection?', answer: 'Unlike centralized services, DFPN uses multiple independent workers with different models. Results are aggregated into consensus verdicts with full on-chain transparency. No single entity controls detection.' },
  { question: 'What blockchain does DFPN use?', answer: 'DFPN runs on Solana for fast, low-cost transactions. All requests, results, and reputation data are stored on-chain.' },
  { question: 'What types of deepfakes can DFPN detect?', answer: 'DFPN supports face manipulation, AI-generated images, video authenticity, and voice cloning detection through four specialized models.' },
  { question: 'Is DFPN live?', answer: 'DFPN is currently in the testnet pilot phase. See the Roadmap for timeline details.' },
]

const workerFaqs = [
  { question: 'How do I become a worker?', answer: 'Install the worker client, set up a Solana wallet, acquire at least 5,000 DFPN tokens for staking, configure your models, and register on-chain. See the Participate page for detailed steps.' },
  { question: 'What hardware do I need?', answer: 'Minimum: 8-core CPU, 32GB RAM, RTX 3080 GPU (10GB VRAM), 500GB SSD. Recommended: 16+ cores, 64GB RAM, RTX 4090 or A100.' },
  { question: 'How much can I earn?', answer: 'Earnings depend on task volume, accuracy, and stake weight. Workers receive 65% of request fees plus epoch-based rewards from the token emission schedule.' },
  { question: 'What happens if I submit incorrect results?', answer: 'Invalid results trigger a 10% stake slash. Repeated failures escalate penalties. Fraud or collusion can result in 25-50% slashing.' },
  { question: 'Can I run a CPU-only node?', answer: 'Yes, but GPU nodes process tasks much faster. CPU-only nodes handle image analysis in ~500-800ms vs 50-100ms on GPU. Video analysis is significantly slower on CPU.' },
]

const tokenFaqs = [
  { question: 'What is the DFPN token used for?', answer: 'DFPN is used for staking (workers and model developers), paying analysis fees, earning rewards, and participating in governance.' },
  { question: 'How does staking work?', answer: 'Workers must stake at least 5,000 DFPN. Model developers stake 20,000 DFPN per model version. Stakes can be slashed for bad behavior and earn rewards for good performance.' },
  { question: 'What is slashing?', answer: "Slashing removes a portion of a participant's staked tokens as penalty. Rates: 10% for invalid results, 1-3% for missed deadlines, 25-50% for fraud or collusion." },
]

const securityFaqs = [
  { question: 'How does commit-reveal prevent cheating?', answer: 'Workers submit a hash of their result before seeing other answers. After all commits, they reveal the actual results. This prevents copying and ensures independent analysis.' },
  { question: 'What if workers disagree?', answer: 'When workers disagree, the system uses reputation-weighted consensus. Workers who consistently agree with ground truth earn higher reputation and their votes carry more weight.' },
]

const allFaqs = [...generalFaqs, ...workerFaqs, ...tokenFaqs, ...securityFaqs]

const faqLd = {
  '@type': 'FAQPage',
  mainEntity: allFaqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
}

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://dfpn.cryptuon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: 'https://dfpn.cryptuon.com/learn' },
    { '@type': 'ListItem', position: 3, name: 'FAQ', item: 'https://dfpn.cryptuon.com/learn/faq' },
  ],
}
---

<DashboardLayout
  title="FAQ - Deepfake Proof Network | DFPN"
  description="Frequently asked questions about DFPN: how deepfake detection works, staking requirements, worker hardware specs, earning rewards, and security."
>
  <Fragment slot="head">
    <JsonLd data={[faqLd, breadcrumbLd]} />
  </Fragment>

  <div class="space-y-12">
    <!-- Hero -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-8 text-center space-y-4">
      <h1 class="text-4xl font-bold text-white">Frequently Asked Questions</h1>
      <p class="text-lg text-gray-400 max-w-3xl mx-auto">
        Everything you need to know about the Deepfake Proof Network, from technical details to tokenomics.
      </p>
    </section>

    <!-- General -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">General</h2>
      <FaqAccordion items={generalFaqs} client:visible />
    </section>

    <!-- Workers -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Workers</h2>
      <FaqAccordion items={workerFaqs} client:visible />
    </section>

    <!-- Tokens & Staking -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Tokens &amp; Staking</h2>
      <FaqAccordion items={tokenFaqs} client:visible />
    </section>

    <!-- Security -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Security</h2>
      <FaqAccordion items={securityFaqs} client:visible />
    </section>

    <!-- CTA -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Still have questions?</h3>
      <div class="flex flex-wrap gap-4">
        <a href="/learn" class="px-5 py-2.5 bg-dfpn-primary text-white text-sm font-medium rounded-lg hover:bg-dfpn-primary/80 transition-colors">
          Back to Learn
        </a>
        <a href="/learn/participate/workers" class="px-5 py-2.5 bg-dfpn-surface border border-dfpn-border text-gray-400 text-sm font-medium rounded-lg hover:border-dfpn-primary/30 transition-colors">
          Become a Worker
        </a>
      </div>
    </section>
  </div>
</DashboardLayout>
