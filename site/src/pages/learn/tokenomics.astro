---
import DashboardLayout from '../../components/layout/DashboardLayout.astro'
import JsonLd from '../../components/seo/JsonLd.astro'
import StatHighlight from '../../components/learn/StatHighlight.astro'
import ComparisonTable from '../../components/learn/ComparisonTable.astro'

const webPageLd = {
  '@type': 'WebPage',
  name: 'DFPN Token Economics',
  description: 'DFPN token supply, allocation, emission schedule, fee distribution, staking requirements, and slashing penalties explained.',
  url: 'https://dfpn.cryptuon.com/learn/tokenomics',
}

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://dfpn.cryptuon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: 'https://dfpn.cryptuon.com/learn' },
    { '@type': 'ListItem', position: 3, name: 'Tokenomics', item: 'https://dfpn.cryptuon.com/learn/tokenomics' },
  ],
}

const allocationSegments = [
  { label: 'Network Rewards', pct: 38, color: 'bg-dfpn-primary' },
  { label: 'Treasury', pct: 20, color: 'bg-blue-500' },
  { label: 'Team & Advisors', pct: 18, color: 'bg-emerald-500' },
  { label: 'Ecosystem', pct: 12, color: 'bg-orange-500' },
  { label: 'Strategic', pct: 7, color: 'bg-pink-500' },
  { label: 'Liquidity', pct: 5, color: 'bg-cyan-500' },
]

const emissionsColumns = [
  { key: 'year', label: 'Year' },
  { key: 'rate', label: 'Emission Rate' },
  { key: 'tokens', label: 'Tokens' },
]

const emissionsRows = [
  { year: 'Year 1', rate: '12%', tokens: '120,000,000' },
  { year: 'Year 2', rate: '9%', tokens: '90,000,000' },
  { year: 'Year 3', rate: '6%', tokens: '60,000,000' },
  { year: 'Year 4', rate: '4%', tokens: '40,000,000' },
  { year: 'Year 5', rate: '3%', tokens: '30,000,000' },
  { year: 'Year 6', rate: '2%', tokens: '20,000,000' },
  { year: 'Year 7', rate: '1%', tokens: '10,000,000' },
  { year: 'Year 8', rate: '1%', tokens: '10,000,000' },
]

const stakingColumns = [
  { key: 'role', label: 'Role' },
  { key: 'minimumStake', label: 'Minimum Stake' },
  { key: 'purpose', label: 'Purpose' },
]

const stakingRows = [
  { role: 'Worker', minimumStake: '5,000 DFPN', purpose: 'Skin in the game for honest detection' },
  { role: 'Model Developer', minimumStake: '20,000 DFPN', purpose: 'Quality commitment per model version' },
  { role: 'Challenger', minimumStake: '5% of disputed reward', purpose: 'Cost to initiate a dispute' },
]

const slashingColumns = [
  { key: 'violation', label: 'Violation' },
  { key: 'penalty', label: 'Penalty' },
]

const slashingRows = [
  { violation: 'Invalid Results', penalty: '10% of stake' },
  { violation: 'Missed Deadlines', penalty: '1-3% of stake' },
  { violation: 'Repeated Failures', penalty: 'Progressive escalation' },
  { violation: 'Fraud or Collusion', penalty: '25-50% of stake' },
]
---

<DashboardLayout
  title="DFPN Token Economics | Deepfake Proof Network"
  description="DFPN token supply, allocation, emission schedule, fee distribution, staking requirements, and slashing penalties explained."
>
  <Fragment slot="head">
    <JsonLd data={[webPageLd, breadcrumbLd]} />
  </Fragment>

  <div class="space-y-12">
    <!-- Hero -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-8">
      <h1 class="text-4xl font-bold text-white mb-4">DFPN Token Economics</h1>
      <p class="text-lg text-gray-400 max-w-3xl">
        The DFPN token powers the network's economic incentive layer, aligning workers, clients, and model developers around accurate deepfake detection.
      </p>
      <div class="flex gap-12 pt-6">
        <StatHighlight value="1B" label="Total Supply" />
        <StatHighlight value="DFPN" label="SPL Token" color="text-emerald-400" />
        <StatHighlight value="38%" label="Network Rewards" color="text-blue-400" />
      </div>
    </section>

    <!-- Token Allocation -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Token Allocation</h2>
      <div class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6 space-y-4">
        <!-- Bar chart -->
        <div class="flex h-8 rounded-lg overflow-hidden">
          {allocationSegments.map((seg) => (
            <div class:list={[seg.color, "flex items-center justify-center text-xs font-medium text-white"]} style={`width: ${seg.pct}%`}>
              {seg.pct >= 7 ? `${seg.pct}%` : ''}
            </div>
          ))}
        </div>
        <!-- Legend -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          {allocationSegments.map((seg) => (
            <div class="flex items-center gap-2">
              <div class:list={["w-3 h-3 rounded-sm", seg.color]}></div>
              <span class="text-sm text-gray-400">{seg.label} ({seg.pct}%)</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Emissions Schedule -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Emissions Schedule</h2>
      <ComparisonTable columns={emissionsColumns} rows={emissionsRows} />
    </section>

    <!-- Fee Distribution -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-2">Fee Distribution</h2>
      <p class="text-gray-400 mb-6">When a client pays for a detection request, the fee is split across the network:</p>
      <div class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6 space-y-4">
        <div class="flex h-8 rounded-lg overflow-hidden">
          <div class="bg-dfpn-primary flex items-center justify-center text-xs font-medium text-white" style="width: 70%">70%</div>
          <div class="bg-emerald-500 flex items-center justify-center text-xs font-medium text-white" style="width: 20%">20%</div>
          <div class="bg-blue-500 flex items-center justify-center text-xs font-medium text-white" style="width: 10%">10%</div>
        </div>
        <div class="flex gap-6">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-sm bg-dfpn-primary"></div>
            <span class="text-sm text-gray-400">Workers (70%)</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-sm bg-emerald-500"></div>
            <span class="text-sm text-gray-400">Model Developers (20%)</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-sm bg-blue-500"></div>
            <span class="text-sm text-gray-400">Treasury (10%)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Staking Requirements -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Staking Requirements</h2>
      <ComparisonTable columns={stakingColumns} rows={stakingRows} />
    </section>

    <!-- Slashing Penalties -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Slashing Penalties</h2>
      <ComparisonTable columns={slashingColumns} rows={slashingRows} />
    </section>

    <!-- Navigation -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Continue learning</h3>
      <div class="flex flex-wrap gap-4">
        <a href="/learn" class="px-5 py-2.5 bg-dfpn-primary text-white text-sm font-medium rounded-lg hover:bg-dfpn-primary/80 transition-colors">
          What is DFPN?
        </a>
        <a href="/learn/how-it-works" class="px-5 py-2.5 bg-dfpn-surface border border-dfpn-border text-gray-400 text-sm font-medium rounded-lg hover:border-dfpn-primary/30 transition-colors">
          How It Works
        </a>
        <a href="/learn/detection-models" class="px-5 py-2.5 bg-dfpn-surface border border-dfpn-border text-gray-400 text-sm font-medium rounded-lg hover:border-dfpn-primary/30 transition-colors">
          Detection Models
        </a>
      </div>
    </section>
  </div>
</DashboardLayout>
