---
import DashboardLayout from '../../../components/layout/DashboardLayout.astro'
import JsonLd from '../../../components/seo/JsonLd.astro'
import ParticipateTabNav from '../../../components/learn/ParticipateTabNav.astro'
import InfoCard from '../../../components/learn/InfoCard.astro'
import ComparisonTable from '../../../components/learn/ComparisonTable.astro'
import StepIndicator from '../../../components/learn/StepIndicator.astro'

const webPageLd = {
  '@type': 'WebPage',
  name: 'Submit Media for Deepfake Analysis',
  description: 'How to submit images, videos, and audio to DFPN for deepfake detection. Integration options, fee tiers, and use cases.',
  url: 'https://dfpn.cryptuon.com/learn/participate/clients',
}

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://dfpn.cryptuon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: 'https://dfpn.cryptuon.com/learn' },
    { '@type': 'ListItem', position: 3, name: 'Participate', item: 'https://dfpn.cryptuon.com/learn/participate/workers' },
    { '@type': 'ListItem', position: 4, name: 'Clients', item: 'https://dfpn.cryptuon.com/learn/participate/clients' },
  ],
}

const howItWorksSteps = [{number:1,title:'Upload',description:'Upload media to IPFS, Arweave, or S3.'},{number:2,title:'Request',description:'Submit analysis request with hash, modalities, and fee.'},{number:3,title:'Wait',description:'Multiple workers analyze independently.'},{number:4,title:'Result',description:'Receive consensus verdict with confidence score.'}]

const feeColumns = [{key:'modality',label:'Modality'},{key:'baseFee',label:'Base Fee'},{key:'typicalTime',label:'Typical Time'}]
const feeRows = [{modality:'Image Authenticity',baseFee:'~0.002 SOL',typicalTime:'1-2 seconds'},{modality:'Face Manipulation',baseFee:'~0.003 SOL',typicalTime:'1-2 seconds'},{modality:'AI-Generated Image',baseFee:'~0.003 SOL',typicalTime:'1-2 seconds'},{modality:'Video Authenticity',baseFee:'~0.008 SOL',typicalTime:'5-30 seconds'},{modality:'Voice Cloning',baseFee:'~0.004 SOL',typicalTime:'2-5 seconds'}]

const integrationCards = [
  { title: 'TypeScript SDK', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', description: 'Easiest for JS/TS apps. Full type safety and helper methods.' },
  { title: 'Python SDK', icon: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z', description: 'For Python applications and data pipelines.' },
  { title: 'REST API', icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9', description: 'Quick integration via the indexer HTTP endpoints.' },
  { title: 'Direct RPC', icon: 'M13 10V3L4 14h7v7l9-11h-7z', description: 'Advanced: interact directly with Solana programs.' },
]

const useCaseCards = [
  { title: 'Content Moderation', icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z', description: 'Automatically flag deepfakes in user-generated content.' },
  { title: 'Journalism', icon: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2', description: 'Verify authenticity of images and videos before publication.' },
  { title: 'Identity Verification', icon: 'M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0', description: 'Detect face swaps in KYC processes.' },
  { title: 'Social Media', icon: 'M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z', description: 'Protect platforms from AI-generated misinformation.' },
]
---

<DashboardLayout
  title="Submit Media for Deepfake Analysis | DFPN Clients"
  description="How to submit images, videos, and audio to DFPN for deepfake detection. Integration options, fee tiers, and use cases."
>
  <Fragment slot="head">
    <JsonLd data={[webPageLd, breadcrumbLd]} />
  </Fragment>

  <div class="space-y-12">
    <!-- Title -->
    <h1 class="text-3xl font-bold text-white">Participate in DFPN</h1>

    <!-- Tab Nav -->
    <ParticipateTabNav />

    <!-- Hero -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-8 text-center space-y-4">
      <h2 class="text-3xl font-bold text-white">Submit Media for Analysis</h2>
      <p class="text-lg text-gray-400 max-w-3xl mx-auto">
        Clients submit images, videos, and audio to the DFPN network for deepfake detection.
        Multiple independent workers analyze each request and return a consensus verdict.
      </p>
    </section>

    <!-- How It Works -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">How It Works</h2>
      <StepIndicator steps={howItWorksSteps} direction="horizontal" />
    </section>

    <!-- Integration Options -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Integration Options</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {integrationCards.map((card) => (
          <InfoCard icon={card.icon} title={card.title} description={card.description} />
        ))}
      </div>
    </section>

    <!-- Fee Tiers -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Fee Tiers</h2>
      <ComparisonTable columns={feeColumns} rows={feeRows} />
    </section>

    <!-- Fee Distribution -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Fee Distribution</h2>
      <div class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
        <div class="flex w-full h-8 rounded-lg overflow-hidden">
          <div class="bg-dfpn-primary flex items-center justify-center text-xs font-medium text-white" style="width: 65%">
            65% Workers
          </div>
          <div class="bg-emerald-600 flex items-center justify-center text-xs font-medium text-white" style="width: 20%">
            20% Model Devs
          </div>
          <div class="bg-amber-600 flex items-center justify-center text-xs font-medium text-white" style="width: 10%">
            10% Treasury
          </div>
          <div class="bg-blue-600 flex items-center justify-center text-xs font-medium text-white" style="width: 5%">
            5% Ins.
          </div>
        </div>
        <div class="flex flex-wrap gap-4 mt-4 text-sm text-gray-400">
          <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-dfpn-primary"></span> 65% Workers</span>
          <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-emerald-600"></span> 20% Model Developers</span>
          <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-amber-600"></span> 10% Treasury</span>
          <span class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-blue-600"></span> 5% Insurance Fund</span>
        </div>
      </div>
    </section>

    <!-- Use Cases -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Use Cases</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {useCaseCards.map((card) => (
          <InfoCard icon={card.icon} title={card.title} description={card.description} />
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Ready to integrate?</h3>
      <div class="flex flex-wrap gap-4">
        <a href="/learn" class="px-5 py-2.5 bg-dfpn-primary text-white text-sm font-medium rounded-lg hover:bg-dfpn-primary/80 transition-colors">
          Back to Learn
        </a>
        <a href="/learn/faq" class="px-5 py-2.5 bg-dfpn-surface border border-dfpn-border text-gray-400 text-sm font-medium rounded-lg hover:border-dfpn-primary/30 transition-colors">
          Read the FAQ
        </a>
      </div>
    </section>
  </div>
</DashboardLayout>
