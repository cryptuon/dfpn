---
import DashboardLayout from '../../../components/layout/DashboardLayout.astro'
import JsonLd from '../../../components/seo/JsonLd.astro'
import ParticipateTabNav from '../../../components/learn/ParticipateTabNav.astro'
import InfoCard from '../../../components/learn/InfoCard.astro'
import ComparisonTable from '../../../components/learn/ComparisonTable.astro'
import StepIndicator from '../../../components/learn/StepIndicator.astro'

const webPageLd = {
  '@type': 'WebPage',
  name: 'Run a DFPN Detection Node',
  description: 'How to become a DFPN worker: hardware requirements, staking, setup steps, rewards, and slashing penalties for running deepfake detection nodes.',
  url: 'https://dfpn.cryptuon.com/learn/participate/workers',
}

const breadcrumbLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://dfpn.cryptuon.com/' },
    { '@type': 'ListItem', position: 2, name: 'Learn', item: 'https://dfpn.cryptuon.com/learn' },
    { '@type': 'ListItem', position: 3, name: 'Participate', item: 'https://dfpn.cryptuon.com/learn/participate/workers' },
    { '@type': 'ListItem', position: 4, name: 'Workers', item: 'https://dfpn.cryptuon.com/learn/participate/workers' },
  ],
}

const hardwareColumns = [{key:'tier',label:'Tier'},{key:'cpu',label:'CPU'},{key:'ram',label:'RAM'},{key:'gpu',label:'GPU'},{key:'storage',label:'Storage'},{key:'network',label:'Network'}]
const hardwareRows = [{tier:'Entry',cpu:'8 cores',ram:'32 GB',gpu:'RTX 3080 10 GB',storage:'500 GB SSD',network:'100 Mbps'},{tier:'Mid',cpu:'16 cores',ram:'64 GB',gpu:'RTX 4090 24 GB',storage:'1 TB NVMe',network:'500 Mbps'},{tier:'Pro',cpu:'32+ cores',ram:'128 GB',gpu:'A100 80 GB',storage:'2 TB NVMe',network:'1 Gbps'}]

const gettingStartedSteps = [{number:1,title:'Install Worker Client',description:'Clone the repo and build the dfpn-worker binary.'},{number:2,title:'Set Up Wallet',description:'Generate or import a Solana keypair.'},{number:3,title:'Fund Wallet',description:'Get SOL for transactions and DFPN for staking.'},{number:4,title:'Configure Models',description:'Run the setup script to download detection models.'},{number:5,title:'Configure Worker',description:'Edit config.yaml with modalities, fees, and concurrency.'},{number:6,title:'Register On-Chain',description:'Stake DFPN and register as a worker.'},{number:7,title:'Start Worker',description:'Launch the daemon and begin processing tasks.'}]

const slashingColumns = [{key:'violation',label:'Violation'},{key:'penalty',label:'Penalty'},{key:'details',label:'Details'}]
const slashingRows = [{violation:'Invalid Results',penalty:'10% stake',details:'Results that disagree with consensus'},{violation:'Missed Deadlines',penalty:'1-3% stake',details:'Failing to submit within the commit window'},{violation:'Repeated Failures',penalty:'Progressive',details:'Escalating penalties for >20% failure rate'},{violation:'Fraud or Collusion',penalty:'25-50% stake',details:'Coordinated manipulation of results'}]
---

<DashboardLayout
  title="Run a DFPN Detection Node | Workers"
  description="How to become a DFPN worker: hardware requirements, staking, setup steps, rewards, and slashing penalties for running deepfake detection nodes."
>
  <Fragment slot="head">
    <JsonLd data={[webPageLd, breadcrumbLd]} />
  </Fragment>

  <div class="space-y-12">
    <!-- Title -->
    <h1 class="text-3xl font-bold text-white">Participate in DFPN</h1>

    <!-- Tab Nav -->
    <ParticipateTabNav />

    <!-- Hero -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-8 text-center space-y-4">
      <h2 class="text-3xl font-bold text-white">Run a Detection Node</h2>
      <p class="text-lg text-gray-400 max-w-3xl mx-auto">
        Workers provide GPU and CPU hardware to analyze media for deepfakes.
        Earn DFPN tokens by running detection models and submitting honest results.
      </p>
    </section>

    <!-- What You Provide vs Receive -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">What You Provide vs What You Receive</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <InfoCard
          icon="M5 12h14M12 5l7 7-7 7"
          title="You Provide"
          description="GPU/CPU hardware, detection models, storage, stable internet, and a 5,000 DFPN stake."
        />
        <InfoCard
          icon="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          title="You Receive"
          description="Task assignments, DFPN token rewards, a reputation score, and 65% of request fees."
        />
      </div>
    </section>

    <!-- Hardware Requirements -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Hardware Requirements</h2>
      <ComparisonTable columns={hardwareColumns} rows={hardwareRows} />
    </section>

    <!-- Getting Started -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">Getting Started</h2>
      <StepIndicator steps={gettingStartedSteps} direction="vertical" />
    </section>

    <!-- Slashing Penalties -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-4">Slashing Penalties</h2>
      <p class="text-gray-400 mb-4">Workers who submit incorrect or late results face stake slashing. This ensures network reliability.</p>
      <ComparisonTable columns={slashingColumns} rows={slashingRows} />
    </section>

    <!-- CTA -->
    <section class="bg-dfpn-surface border border-dfpn-border rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-4">Ready to run a node?</h3>
      <div class="flex flex-wrap gap-4">
        <a href="/learn" class="px-5 py-2.5 bg-dfpn-primary text-white text-sm font-medium rounded-lg hover:bg-dfpn-primary/80 transition-colors">
          Back to Learn
        </a>
        <a href="/learn/faq" class="px-5 py-2.5 bg-dfpn-surface border border-dfpn-border text-gray-400 text-sm font-medium rounded-lg hover:border-dfpn-primary/30 transition-colors">
          Read the FAQ
        </a>
      </div>
    </section>
  </div>
</DashboardLayout>
